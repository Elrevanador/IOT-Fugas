NODE_ENV=production
DB_SYNC_ALTER=false
DB_USE_SYNC=true
DB_RUN_MIGRATIONS=true

JWT_SECRET=pon_un_secreto_largo_y_random
INGEST_API_KEY=pon_una_clave_larga_y_random_para_dispositivos
FRONTEND_ORIGIN=https://tu-frontend.railway.app
DATABASE_URL=mysql://usuario:password@host:puerto/base
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_REGISTER_RATE_LIMIT_MAX=5

# Alternativa usando variables inyectadas por un servicio MySQL de Railway:
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_USER=${{MySQL.MYSQLUSER}}
DB_PASS=${{MySQL.MYSQLPASSWORD}}
DB_NAME=${{MySQL.MYSQLDATABASE}}
