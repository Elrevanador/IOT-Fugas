PORT=3000
NODE_ENV=development
DB_SYNC_ALTER=false
DB_USE_SYNC=true
DB_RUN_MIGRATIONS=true
TRUST_PROXY=false

JWT_SECRET=replace_with_a_long_random_secret
INGEST_API_KEY=replace_with_a_long_random_device_key
# En producción, lista cada origen del SPA (con puerto). localhost/127.0.0.1 con cualquier puerto
# también se permiten por código para pruebas locales (ver isLoopbackBrowserOrigin en app.js).
FRONTEND_ORIGIN=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8001,http://127.0.0.1:8001,http://localhost:4200,http://127.0.0.1:4200
DATABASE_URL=

# Local primero: usa tu backend en development, frontend estatico en :8000
# y la misma INGEST_API_KEY en simulacion/modulos/config.cpp.
DB_HOST=localhost
DB_PORT=3306
DB_USER=iot_user
DB_PASS=change_this_password
DB_NAME=iot_water

# Railway produccion:
# - No subas tu .env real al repositorio.
# - En Railway deja que la plataforma inyecte PORT.
# - Usa NODE_ENV=production, DB_USE_SYNC=false, DB_SYNC_ALTER=false, DB_RUN_MIGRATIONS=true, TRUST_PROXY=1.
# - FRONTEND_ORIGIN debe ser la URL publica real del frontend, no localhost.
# - Si agregas MySQL en Railway, puedes usar DATABASE_URL=${{ MySQL.MYSQL_URL }}
#   o mapear las variables:
#   DB_HOST=${{ MySQL.MYSQLHOST }}
#   DB_PORT=${{ MySQL.MYSQLPORT }}
#   DB_USER=${{ MySQL.MYSQLUSER }}
#   DB_PASS=${{ MySQL.MYSQLPASSWORD }}
#   DB_NAME=${{ MySQL.MYSQLDATABASE }}
